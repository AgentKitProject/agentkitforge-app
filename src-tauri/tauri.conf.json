{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentKitForge",
  "version": "0.1.0",
  "identifier": "com.agentkitforge.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AgentKitForge",
        "width": 1200,
        "height": 780,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "resources": ["backend/validate-agent-kit.mjs", "backend/create-agent-kit.mjs"]
  }
}
