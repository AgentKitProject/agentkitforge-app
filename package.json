{
  "name": "agentkitforge-app",
  "private": true,
  "version": "0.4.1",
  "description": "Desktop app for building, validating, packaging, installing, and using Agent Kits.",
  "author": "AgentKitForge",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:frontend": "vite --host 127.0.0.1 --port 1420",
    "build": "npm run build:backend && tsc && vite build",
    "build:backend": "node scripts/build-backend.mjs",
    "check:backend": "node scripts/check-backend.mjs",
    "check:tauri-sidecar": "node scripts/check-tauri-sidecar.mjs",
    "build:frontend": "tsc && vite build",
    "build:tauri": "tauri build",
    "check": "tsc && cargo check --manifest-path src-tauri/Cargo.toml",
    "test": "node --test tests/*.test.mjs",
    "smoke": "npm run check && npm run build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@agentkitforge/core": "^0.2.0",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@tauri-apps/cli": "^2.5.0",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.0",
    "rollup": "^4.60.4",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
