{
  "name": "agentkitforge-app",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop app for building, validating, packaging, installing, and using Agent Kits.",
  "author": "AgentKitForge",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:frontend": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc && vite build",
    "build:frontend": "tsc && vite build",
    "build:tauri": "tauri build",
    "check": "tsc && cargo check --manifest-path src-tauri/Cargo.toml",
    "smoke": "npm run check && npm run build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.5.0",
    "@agentkitforge/core": "^0.1.1",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.5.0",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
